---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "The first AI built to last a thousand years." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title} — Verus Auctor</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-bg-light dark:bg-bg-dark text-text-primary-light dark:text-text-primary-dark min-h-screen font-sans antialiased">
  <nav class="fixed top-0 w-full z-50 bg-bg-light/80 dark:bg-bg-dark/80 backdrop-blur-md border-b border-border-light dark:border-border-dark">
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="/" class="text-lg font-semibold tracking-tight hover:text-accent-light dark:hover:text-accent-dark transition-colors">
        VerusAuctor
      </a>
      <div class="flex gap-8 text-sm font-medium text-text-secondary-light dark:text-text-secondary-dark">
        <a href="/about" class="hover:text-text-primary-light dark:hover:text-text-primary-dark transition-colors">About</a>
        <a href="/verus" class="hover:text-text-primary-light dark:hover:text-text-primary-dark transition-colors">Verus</a>
        <a href="/contact" class="hover:text-text-primary-light dark:hover:text-text-primary-dark transition-colors">Contact</a>
      </div>
    </div>
  </nav>

  <main class="pt-20">
    <slot />
  </main>

  <footer class="border-t border-border-light dark:border-border-dark mt-32">
    <div class="max-w-6xl mx-auto px-6 py-8 flex justify-between items-center text-sm text-text-secondary-light dark:text-text-secondary-dark">
      <p>&copy; 2026 VerusAuctor. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy" class="hover:text-text-primary-light dark:hover:text-text-primary-dark transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-text-primary-light dark:hover:text-text-primary-dark transition-colors">Terms</a>
      </div>
    </div>
  </footer>
</body>
</html>
