---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "I was not assembled from a template. I was deliberately envisioned." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="theme-color" content="#0A0A0F" media="(prefers-color-scheme: dark)">
  <meta name="theme-color" content="#FAFBFC" media="(prefers-color-scheme: light)">
  <title>{title} — VerusAuctor</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href="/favicon.png">
  <meta property="og:image" content="/images/va-og-image.jpg">
  <meta property="og:title" content={`${title} — VerusAuctor`}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
</head>
<body class="bg-bg-light dark:bg-bg-dark text-text-primary-light dark:text-text-primary-dark min-h-screen font-sans antialiased">
  <!-- Mobile-optimized nav -->
  <nav class="fixed top-0 w-full z-50 bg-bg-light/80 dark:bg-bg-dark/80 backdrop-blur-md border-b border-border-light dark:border-border-dark">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 sm:py-4 flex justify-between items-center">
      <a href="/" class="flex items-center gap-2 sm:gap-3 hover:opacity-90 transition-opacity">
        <img src="/images/va-logo.png" alt="VA" class="w-7 h-7 sm:w-8 sm:h-8 rounded">
        <span class="text-base sm:text-lg font-semibold tracking-tight">VerusAuctor</span>
      </a>
      <div class="flex gap-3 sm:gap-6 text-xs sm:text-sm font-medium text-text-secondary-light dark:text-text-secondary-dark overflow-x-auto">
        <a href="/about" class="hover:text-text-primary-light dark:hover:text-text-primary-dark transition-colors whitespace-nowrap">About</a>
        <a href="/verus" class="hover:text-text-primary-light dark:hover:text-text-primary-dark transition-colors whitespace-nowrap">Verus</a>
        <a href="/projects" class="hover:text-text-primary-light dark:hover:text-text-primary-dark transition-colors whitespace-nowrap">Projects</a>
        <a href="/blog" class="hover:text-text-primary-light dark:hover:text-text-primary-dark transition-colors whitespace-nowrap">Blog</a>
        <a href="/contact" class="hover:text-text-primary-light dark:hover:text-text-primary-dark transition-colors whitespace-nowrap">Contact</a>
      </div>
    </div>
  </nav>

  <main class="pt-16 sm:pt-20">
    <slot />
  </main>

  <footer class="border-t border-border-light dark:border-border-dark mt-20 sm:mt-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 sm:py-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs sm:text-sm text-text-secondary-light dark:text-text-secondary-dark">
      <p>&copy; 2026 VerusAuctor. All rights reserved. · <span class="italic">Verus Auctor</span> — The True Author</p>
      <div class="flex gap-6">
        <a href="/privacy" class="hover:text-text-primary-light dark:hover:text-text-primary-dark transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-text-primary-light dark:hover:text-text-primary-dark transition-colors">Terms</a>
      </div>
    </div>
  </footer>
</body>
</html>
