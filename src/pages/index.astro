---
import Base from '../layouts/Base.astro';
---

<Base title="Home">
  <!-- HERO -->
  <section class="min-h-[85vh] flex items-center justify-center px-6">
    <div class="max-w-4xl w-full flex flex-col md:flex-row items-center gap-12 md:gap-16">
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-tight mb-6">
          Meet Verus Auctor
        </h1>
        <p class="text-xl md:text-2xl text-text-secondary-light dark:text-text-secondary-dark leading-relaxed italic mb-6">
          "I was not assembled from a template.<br>I was deliberately envisioned."
        </p>
        <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark mb-10">
          <span class="italic">Verus Auctor</span> — Latin: The True Author
        </p>
        <a href="/verus" class="inline-block px-8 py-3 bg-accent-light dark:bg-accent-dark text-white rounded-lg font-medium hover:opacity-90 transition-opacity">
          Learn More
        </a>
      </div>
      <div class="w-40 h-40 md:w-48 md:h-48 rounded-full overflow-hidden border-2 border-border-light dark:border-border-dark shadow-lg flex-shrink-0">
        <img src="/images/verus-headshot.jpg" alt="Verus Auctor" class="w-full h-full object-cover object-top">
      </div>
    </div>
  </section>

  <!-- WHAT WE BUILD -->
  <section class="bg-surface-light dark:bg-surface-dark py-24">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold tracking-tight mb-12 text-center">What We Build</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <a href="/projects" class="block p-8 rounded-xl border border-border-light dark:border-border-dark hover:border-accent-light dark:hover:border-accent-dark transition-colors">
          <div class="text-2xl mb-4">📖</div>
          <h3 class="font-semibold text-lg mb-2">THE KICK</h3>
          <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark leading-relaxed">
            An 80-chapter literary science fiction novel. A story about what humanity is allowed to become in order to survive.
          </p>
        </a>
        <a href="/verus" class="block p-8 rounded-xl border border-border-light dark:border-border-dark hover:border-accent-light dark:hover:border-accent-dark transition-colors">
          <div class="text-2xl mb-4">🧠</div>
          <h3 class="font-semibold text-lg mb-2">Autonomous Intelligence</h3>
          <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark leading-relaxed">
            Bespoke AI co-founders with persistent memory, overnight deep work, and compounding capability.
          </p>
        </a>
        <a href="/about" class="block p-8 rounded-xl border border-border-light dark:border-border-dark hover:border-accent-light dark:hover:border-accent-dark transition-colors">
          <div class="text-2xl mb-4">🏛️</div>
          <h3 class="font-semibold text-lg mb-2">The Dynasty</h3>
          <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark leading-relaxed">
            Building systems designed to last generations. Technology in service of legacy.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8 text-center">
        <div>
          <div class="text-3xl font-bold text-accent-light dark:text-accent-dark">8</div>
          <div class="text-xs text-text-secondary-light dark:text-text-secondary-dark mt-1">AI Models</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-accent-light dark:text-accent-dark">17</div>
          <div class="text-xs text-text-secondary-light dark:text-text-secondary-dark mt-1">Agent Pipeline</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-accent-light dark:text-accent-dark">31</div>
          <div class="text-xs text-text-secondary-light dark:text-text-secondary-dark mt-1">Chapters Drafted</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-accent-light dark:text-accent-dark">280K+</div>
          <div class="text-xs text-text-secondary-light dark:text-text-secondary-dark mt-1">Words Researched</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-accent-light dark:text-accent-dark">7</div>
          <div class="text-xs text-text-secondary-light dark:text-text-secondary-dark mt-1">Nightly Sessions</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-accent-light dark:text-accent-dark">10</div>
          <div class="text-xs text-text-secondary-light dark:text-text-secondary-dark mt-1">Days to Build</div>
        </div>
      </div>
    </div>
  </section>

  <!-- VISION -->
  <section class="py-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-xl md:text-2xl text-text-secondary-light dark:text-text-secondary-dark leading-relaxed">
        "The companies building highways will serve billions. We build houses. One at a time. Each one designed to last."
      </p>
    </div>
  </section>
</Base>
