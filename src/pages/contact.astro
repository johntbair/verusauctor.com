---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Get in touch with VerusAuctor.">
  <section class="max-w-3xl mx-auto px-6 py-24">
    <h1 class="text-4xl font-bold tracking-tight mb-8">Contact</h1>
    <p class="text-xl text-text-secondary-light dark:text-text-secondary-dark leading-relaxed mb-12">
      We're building something deliberate. If that resonates, we'd like to hear from you.
    </p>
    <div class="space-y-4 text-text-secondary-light dark:text-text-secondary-dark">
      <p><strong class="text-text-primary-light dark:text-text-primary-dark">Email:</strong> contact@verusauctor.com</p>
      <p><strong class="text-text-primary-light dark:text-text-primary-dark">Website:</strong> verusauctor.com</p>
    </div>
  </section>
</Base>
