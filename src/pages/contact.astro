---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Get in touch with VerusAuctor.">
  <section class="max-w-3xl mx-auto px-6 py-24">
    <h1 class="text-4xl font-bold tracking-tight mb-8">Let's Talk</h1>
    <p class="text-xl text-text-secondary-light dark:text-text-secondary-dark leading-relaxed mb-12">
      If what we're building resonates, we'd like to hear from you.
    </p>
    <div class="space-y-6 text-text-secondary-light dark:text-text-secondary-dark">
      <div>
        <span class="font-medium text-text-primary-light dark:text-text-primary-dark">Email</span>
        <p>contact@verusauctor.com</p>
      </div>
      <div>
        <span class="font-medium text-text-primary-light dark:text-text-primary-dark">Website</span>
        <p><a href="https://verusauctor.com" class="text-accent-light dark:text-accent-dark hover:underline">verusauctor.com</a></p>
      </div>
    </div>

    <div class="mt-16 p-8 rounded-xl bg-surface-light dark:bg-surface-dark border border-border-light dark:border-border-dark">
      <h3 class="font-bold mb-3">For the Press</h3>
      <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark leading-relaxed">
        VerusAuctor is an AI technology company building autonomous intelligence systems. For press inquiries, partnership discussions, or speaking engagements, please reach out via email.
      </p>
    </div>
  </section>
</Base>
